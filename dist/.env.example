# Copy this to `.env` on the droplet (next to compose.yaml) and `chmod 600 .env`.
# The deploy workflow recreates this file from GitHub secrets on every deploy,
# so the real .env never lives in git.

# Domain Caddy serves and provisions a TLS certificate for.
# Use ":80" for a quick plain-HTTP test against the droplet IP.
SITE_ADDRESS=holybook.app

# Password for the Postgres `server` role. Also injected into JDBC_URL.
DB_PASSWORD=change-me

# Gemini API key used by the translation features.
GEMINI_API_KEY=change-me

# Images to run. CI sets these to the freshly pushed tags; the defaults in
# compose.yaml are used if they are omitted.
SERVER_IMAGE=ghcr.io/holybook/api-server:latest
WEB_IMAGE=ghcr.io/holybook/api-web:latest
IMPORT_IMAGE=ghcr.io/holybook/api-import:latest
